# Solana RPC (Devnet default)
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Instrutor: carteiras que veem o painel "Administrar cursos" (NFT de instrutor em produção)
# Ex.: NEXT_PUBLIC_INSTRUCTOR_WALLETS=addr1,addr2
# NEXT_PUBLIC_INSTRUCTOR_WALLETS=

# Admin: carteiras com acesso ao dashboard Admin (cNFT de admin em produção)
# Ex.: NEXT_PUBLIC_ADMIN_WALLETS=addr1,addr2
# NEXT_PUBLIC_ADMIN_WALLETS=

# On-chain program addresses (deploy your own via docs/DEPLOY-PROGRAM.md)
NEXT_PUBLIC_PROGRAM_ID=
NEXT_PUBLIC_XP_MINT=
NEXT_PUBLIC_BACKEND_SIGNER=
NEXT_PUBLIC_CLUSTER=devnet

# Privy App ID (get one at https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# Optional: Analytics & monitoring
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
# NEXT_PUBLIC_GA4_ID=
# Sentry DSN for error monitoring (e.g. https://xxx@o0.ingest.sentry.io/0)
# NEXT_PUBLIC_SENTRY_DSN=
# PostHog project API key and host (heatmaps, session recording, feature flags)
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sanity CMS (optional — leave unset to use hardcoded course data)
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production

# Sanity write token (server-only, NOT NEXT_PUBLIC). Required for Admin Dashboard writes.
# Get it at: https://www.sanity.io/manage → API → Tokens → Add API token (Editor permission)
# SANITY_API_TOKEN=
